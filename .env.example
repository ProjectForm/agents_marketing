# Configuração da Finlancer Marketing Agency
# Copie este arquivo para .env e preencha os valores

# Anthropic API Key (obrigatório)
# Obter em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google AI API Key (obrigatório para geração de imagens e vídeos)
# Obter em: https://aistudio.google.com/app/apikey
# Usado por: Imagen 2 (imagens) e Veo 3 (vídeos UGC)
GOOGLE_AI_API_KEY=AQ...

# Configurações opcionais
# LOG_LEVEL=INFO
# OUTPUT_DIR=./output
