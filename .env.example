GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional: ANTHROPIC_API_KEY= (if still using Anthropic for some agents)
# Optional: GEMINI_API_KEY= (if still using older Google AI models)

# ── META / FACEBOOK + INSTAGRAM ──────────────────────────────
# Obter em: https://developers.facebook.com/tools/explorer/
# Permissões: pages_manage_posts, pages_read_engagement,
#             instagram_basic, instagram_content_publish
META_ACCESS_TOKEN="seu_page_token_aqui"

# ID da Página do Facebook (número longo)
FACEBOOK_PAGE_ID="seu_page_id_aqui"

# ID da conta Instagram Business (rodar: python publish.py --preview para descobrir)
INSTAGRAM_BUSINESS_ACCOUNT_ID="seu_ig_account_id_aqui"

# Versão da Graph API (não alterar)
META_API_VERSION="v21.0"
